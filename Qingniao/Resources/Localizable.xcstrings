    "onboarding.accessibility.boundary": {
      "comment": "",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "MVP uses this permission only within documented Assistant features. It does not run arbitrary shell commands or upload your data."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "MVP 仅在已说明的 Assistant 功能边界内使用此权限，不执行任意 shell，也不会上传你的数据。"
          }
        }
      }
    },
    "onboarding.accessibility.description": {
      "comment": "",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Assistant needs Accessibility permission for controlled macOS automation paths such as future auto-paste, window control, simulated shortcuts, and controlling other apps."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "Assistant 需要辅助功能权限，用于受控的 macOS 自动化路径，例如后续自动粘贴、窗口控制、模拟快捷键和控制其他 App。"
          }
        }
      }
    },
    "onboarding.accessibility.explain": {
      "comment": "Onboarding accessibility explanation",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Accessibility permission is used for future quick actions (such as auto-paste and simulated shortcuts). You can grant it when you need it."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "辅助功能权限用于未来的快捷操作(如自动粘贴、模拟快捷键)。你可以在用到时再授予。"
          }
        }
      }
    },
    "onboarding.accessibility.later": {
      "comment": "Onboarding accessibility later button",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Maybe later"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "稍后再说"
          }
        }
      }
    },
    "onboarding.accessibility.subtitle": {
      "comment": "",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Required to support safe system-control workflows."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "用于支持安全的系统控制类工作流。"
          }
        }
      }
    },
    "onboarding.accessibility.title": {
      "comment": "",
      "localizations": {
