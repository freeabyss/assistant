    "about.feedback.excluded": {
      "comment": "Feedback excluded text",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Excluded: clipboard history, screenshots, copied files, and automatic crash logs."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "不包含：剪贴板历史、截图、复制的文件和自动崩溃日志。"
          }
        }
      }
    },
    "about.feedback.included": {
      "comment": "Feedback included section title",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Included in the email"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "邮件中包含"
