    "about.checkUpdates": {
      "comment": "Check updates action title",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Check for Updates"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "检查更新"
          }
        }
      }
    },
    "about.copyright.section": {
      "comment": "Copyright section title",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Copyright"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "版权"
          }
        }
      }
    },
    "about.description": {
      "comment": "About product description",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "青鸟 Qingniao is a local-first macOS efficiency center for search, clipboard history, screenshots, commands, and settings."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "青鸟 Qingniao 是本地优先的 macOS 效率中心，聚合搜索、剪贴板历史、截图、命令和设置。"
          }
        }
      }
    },
    "about.feedback": {
      "comment": "Feedback action title",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Send Feedback by Email"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "通过邮件反馈"
          }
        }
      }
    },
    "about.feedback.cancel": {
      "comment": "Feedback cancel button",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Cancel"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "取消"
          }
        }
      }
    },
