    "onboarding.clipboard.point.defaultOn": {
      "comment": "",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Clipboard history is enabled by default for text, images, and file references."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "剪贴板历史默认开启，支持文本、图片和文件引用。"
          }
        }
      }
    },
    "onboarding.clipboard.point.localOnly": {
      "comment": "",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Clipboard data stays on this Mac and is not uploaded, synced, or used for training."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "剪贴板数据仅保存在本机，不上传、不同步、不用于训练。"
          }
        }
