    "about.feedback.openMail": {
      "comment": "Feedback open mail button",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Open Mail"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "打开邮件"
          }
        }
      }
    },
    "about.feedback.sheet.scope": {
      "comment": "Feedback scope text",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Before opening your mail app, review what will be included. You can cancel now. No clipboard history, screenshots, files, or automatic crash logs are attached."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "打开邮件应用前，请先查看将包含的信息范围。你现在可以取消。不会附带剪贴板历史、截图、文件或自动崩溃日志。"
          }
        }
      }
    },
    "about.feedback.sheet.title": {
      "comment": "Feedback sheet title",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Send Feedback"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "发送反馈"
          }
        }
      }
    },
    "about.feedback.summary": {
      "comment": "Feedback summary label",
      "localizations": {
        "en": {
