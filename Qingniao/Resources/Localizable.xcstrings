    "about.release.feedback": {
      "comment": "About feedback commitment",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Feedback is user-initiated email only. The app shows the data scope first and never sends diagnostics silently."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "反馈仅由用户主动通过邮件触发。应用会先展示数据范围，绝不静默发送诊断信息。"
          }
        }
      }
    },
    "about.release.privacy": {
      "comment": "About privacy commitment",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Clipboard history and screenshots stay on this Mac unless you explicitly export or send something yourself."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "剪贴板历史和截图保留在本机，除非你主动导出或发送。"
          }
        }
      }
    },
    "about.release.section": {
      "comment": "Release notes section title",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Release commitments"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "发布承诺"
          }
        }
      }
    },
    "about.release.update": {
      "comment": "About update commitment",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Check for Updates opens the GitHub Releases page for manual download; the MVP does not auto-download, auto-install, or restart to update."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "检查更新会打开 GitHub Releases 页面供你手动下载；MVP 不会自动下载、自动安装或重启更新。"
          }
        }
      }
    },
    "about.subtitle": {
      "comment": "About page subtitle",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
