            "state": "translated",
            "value": "在 Finder 中显示"
          }
        }
      }
    },
    "privacy.clipboard.body": {
      "comment": "Privacy clipboard body",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Clipboard history is stored locally in Application Support. Text metadata is stored in the local database; image and rich-text resources are stored as local files. File clipboard entries save references and paths only, not file contents. You can pause recording in Settings and clear history from the Clipboard History page."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "剪贴板历史保存在本机 Application Support 中。文本元数据保存在本地数据库；图片和富文本资源保存在本地文件。文件剪贴板项只保存引用和路径，不复制文件内容。你可以在设置中暂停记录，并在剪贴板历史页清空历史。"
          }
        }
      }
    },
    "privacy.clipboard.title": {
      "comment": "Privacy clipboard title",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Clipboard history"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "剪贴板历史"
          }
        }
      }
    },
    "privacy.contact": {
      "comment": "Privacy contact format",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Questions? Contact %@."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "如有问题，请联系 %@。"
          }
        }
      }
    },
    "privacy.control.body": {
      "comment": "Privacy user control body",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "You can disable clipboard recording, change the retention period, delete individual history items, or clear all clipboard history. Clearing history requires confirmation and is not automatically uploaded or reported."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "你可以关闭剪贴板记录、调整保留时间、删除单条历史或清空全部剪贴板历史。清空历史需要确认，且不会被自动上传或上报。"
          }
        }
      }
    },
    "privacy.control.title": {
      "comment": "Privacy user control title",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "User controls"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "用户控制"
          }
        }
      }
    },
    "privacy.feedback.body": {
      "comment": "Privacy feedback body",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Feedback is sent only when you click the feedback button, review the data scope, and choose to open your mail app. The prefilled email includes app version, build number, macOS version, an error summary, and your notes. It does not attach clipboard history, screenshots, files, or automatic crash logs."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "反馈仅在你点击反馈按钮、查看数据范围并选择打开邮件应用后发送。预填邮件包含应用版本、构建号、macOS 版本、错误摘要和你的补充说明，不附带剪贴板历史、截图、文件或自动崩溃日志。"
          }
        }
      }
    },
    "privacy.feedback.title": {
      "comment": "Privacy feedback title",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Feedback and diagnostics"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "反馈与诊断"
          }
        }
      }
    },
    "privacy.local.body": {
      "comment": "Privacy local first body",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "青鸟 Qingniao does not upload, sync, or use your clipboard history, screenshots, settings, usage records, or feedback text to train models. There is no account system or cloud sync in the MVP."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "青鸟 Qingniao 不会上传、同步剪贴板历史、截图、设置、使用记录或反馈文本，也不会用这些数据训练模型。MVP 不包含账号系统或云同步。"
          }
        }
      }
    },
    "privacy.local.title": {
      "comment": "Privacy local first title",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Local-first data handling"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "本地优先的数据处理"
          }
        }
      }
    },
    "privacy.screenshot.body": {
      "comment": "Privacy screenshot body",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Screenshots are captured and processed locally. Saving writes PNG files to your configured screenshots folder. Copying writes the image to the system clipboard and follows the same local clipboard-history behavior."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "截图仅在本机捕获和处理。保存会将 PNG 写入你配置的截图目录。复制会写入系统剪贴板，并遵循同样的本地剪贴板历史行为。"
          }
        }
      }
    },
    "privacy.screenshot.title": {
      "comment": "Privacy screenshot title",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Screenshots"
          }
        },
