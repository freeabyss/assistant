<?xml version="1.0" encoding="utf-8"?>
<!--
  Qingniao Appcast Feed
  ======================
  This is a template appcast.xml for Sparkle update checks.

  To publish a real update:
  1. Generate an EdDSA key pair using Sparkle's `generate_keys` tool:
     https://sparkle-project.org/documentation/publishing/#signing-your-update

  2. Replace SUPublicEDKey in Info.plist with the generated public key.

  3. Build the .zip or .dmg archive of your new release.

  4. Sign the archive:
     ./bin/sign_update path/to/Qingniao.zip

  5. Copy the signature output and fill in the `sparkle:edSignature` attribute.

  6. Update the <enclosure> url, version, shortVersionString, and length.

  7. Host this file at the SUFeedURL configured in Info.plist.
     MVP user-facing update checks open GitHub Releases instead of this appcast.
-->
<rss version="2.0" xmlns:sparkle="http://www.andymatuschak.org/xml-namespaces/sparkle" xmlns:dc="http://purl.org/dc/elements/1.1/">
    <channel>
        <title>青鸟 Qingniao</title>
        <link>https://github.com/freeabyss/assistant/releases</link>
        <description>Most recent changes with links to manual GitHub Releases downloads.</description>
        <language>en</language>

        <item>
            <title>Version 0.1.0</title>
            <description><![CDATA[
                <h3>Initial Release</h3>
                <ul>
                    <li>Menu bar Qingniao shell</li>
                    <li>Unified search entry</li>
                    <li>Clipboard history</li>
                    <li>Screenshot tools</li>
                    <li>Built-in safe commands</li>
                </ul>
            ]]></description>
            <pubDate><!-- Thu, 05 Jun 2026 00:00:00 +0000 --></pubDate>
            <sparkle:minimumSystemVersion>13.0</sparkle:minimumSystemVersion>
            <enclosure
                url="https://github.com/freeabyss/assistant/releases/download/v0.1.0/Qingniao-0.1.0.zip"
                sparkle:version="1"
                sparkle:shortVersionString="0.1.0"
                sparkle:edSignature="REPLACE_WITH_EDDSA_SIGNATURE"
                length="0"
                type="application/octet-stream" />
        </item>

    </channel>
</rss>
