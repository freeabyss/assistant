<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <!-- Menu bar app: hide from Dock -->
    <key>LSUIElement</key>
    <true/>

    <!-- App metadata -->
    <key>CFBundleName</key>
    <string>Assistant</string>
    <key>CFBundleDisplayName</key>
    <string>Mac Super Assistant</string>
    <key>CFBundleIdentifier</key>
    <string>com.assistant.app</string>
    <key>CFBundleVersion</key>
    <string>1</string>
    <key>CFBundleShortVersionString</key>
    <string>0.1.0</string>
    <key>CFBundlePackageType</key>
    <string>APPL</string>
    <key>CFBundleExecutable</key>
    <string>$(EXECUTABLE_NAME)</string>
    <key>CFBundleIconFile</key>
    <string>AppIcon</string>
    <key>LSMinimumSystemVersion</key>
    <string>$(MACOSX_DEPLOYMENT_TARGET)</string>

    <!-- Screen recording permission description (ScreenCaptureKit) -->
    <key>NSScreenCaptureUsageInfo</key>
    <string>Mac Super Assistant needs screen recording permission to capture screenshots.</string>

    <!-- AppleScript automation: required for allowed built-in system commands -->
    <key>NSAppleEventsUsageDescription</key>
    <string>Mac Super Assistant uses AppleScript only for allowed built-in commands that you explicitly trigger.</string>

    <!-- Localization -->
    <key>CFBundleLocalizations</key>
    <array>
        <string>en</string>
        <string>zh-Hans</string>
    </array>

    <!-- Sparkle auto-update configuration -->
    <key>SUFeedURL</key>
    <string>https://assistant.app/appcast.xml</string>
    <key>SUPublicEDKey</key>
    <string>REPLACE_WITH_YOUR_EDDSA_PUBLIC_KEY</string>
    <key>SUEnableAutomaticChecks</key>
    <true/>
    <key>SUScheduledCheckInterval</key>
    <integer>86400</integer>
</dict>
</plist>
