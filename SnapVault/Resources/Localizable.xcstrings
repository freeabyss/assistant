    "settings.data.export.footer": {
      "comment": "Section footer for Export",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "JSON includes all data (images as Base64). CSV includes text fields only. Database exports the raw SQLite file."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "JSON 包含所有数据（图片以 Base64 编码）。CSV 仅包含文本字段。数据库导出原始 SQLite 文件。"
          }
        }
      }
    },
    "settings.data.importJson": {
      "comment": "Button to import JSON",
      "localizations": {
