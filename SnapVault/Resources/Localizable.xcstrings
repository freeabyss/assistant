    "settings.behavior.footer": {
      "comment": "Section footer for Behavior settings",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "OCR extracts text from images for search. Polling interval controls how often SnapVault checks the clipboard for new content."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "OCR 从图片中提取文字用于搜索。轮询间隔控制 SnapVault 检查剪贴板新内容的频率。"
          }
        }
      }
    },
    "settings.restoreDefaults": {
      "comment": "Button to restore default settings",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Restore Defaults"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "恢复默认"
          }
        }
      }
    },
    "settings.restoreDefaults.help": {
      "comment": "Tooltip for Restore Defaults button",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Reset all general settings to their default values"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "将所有通用设置恢复为默认值"
          }
        }
      }
