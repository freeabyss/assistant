    },
    "onboarding.clipboard.acknowledge": {
      "comment": "",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "I understand clipboard history is enabled by default and stored locally."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "我已知晓剪贴板历史默认开启，且数据仅本地保存。"
          }
