    "settings.data.clearHistory.confirm.title": {
      "comment": "Title for clear history confirmation dialog",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Are you sure you want to clear all clipboard history?"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "确定要清除所有剪贴板历史吗？"
          }
        }
      }
    },
    "settings.data.clearHistory.confirm.message": {
      "comment": "Message for clear history confirmation dialog",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "This will permanently delete all non-pinned clipboard items. Pinned items will be preserved. This action cannot be undone."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "这将永久删除所有非置顶的剪贴板内容。置顶内容将被保留。此操作不可撤销。"
          }
        }
      }
    },
    "settings.data.clearHistory.confirm.action": {
      "comment": "Action button for clear history confirmation",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Clear All History"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "清除全部历史"
          }
        }
      }
    },
    "settings.data.clearHistory.cancel": {
