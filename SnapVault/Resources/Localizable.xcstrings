    "settings.shortcuts.footer.defaults": {
      "comment": "Footer showing default shortcut values",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Defaults: Open Search ⌥Space · Capture Region ⌘⇧A · Capture Window ⌘⇧W."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "默认：打开搜索 ⌥空格 · 区域截图 ⌘⇧A · 窗口截图 ⌘⇧W。"
          }
        }
      }
    },
    "settings.shortcuts.footer.spotlightWarning": {
      "comment": "Warning about shortcut conflicts",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "If the default shortcut is unavailable on your Mac, record a different one here or during Onboarding."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "如果默认快捷键在你的 Mac 上不可用，请在此处或首次引导中重新录制一个可用快捷键。"
          }
        }
      }
    },
    "settings.shortcuts.footer.instructions": {
      "comment": "Instructions for recording shortcuts",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Click a recorder field and press your desired key combination. Capture Region lets you select an area to screenshot. Capture Window captures the window under your cursor."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "点击录制区域并按下你想要的组合键。区域截图可让你选择截图区域，窗口截图可捕捉光标下的窗口。"
          }
        }
      }
    },
    "settings.data.dbSize": {
