    "settings.data.import.footer": {
      "comment": "Section footer for Import",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Import data from a previously exported JSON file. Duplicate items (same content hash) will be skipped."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "从之前导出的 JSON 文件导入数据。重复内容（相同哈希值）将被跳过。"
          }
        }
      }
    },
