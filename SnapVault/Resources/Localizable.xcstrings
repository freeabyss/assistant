      }
    },
    "onboarding.clipboard.point.localOnly": {
      "comment": "",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Clipboard data stays on this Mac and is not uploaded, synced, or used for training."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "剪贴板数据仅保存在本机，不上传、不同步、不用于训练。"
          }
        }
      }
    },
