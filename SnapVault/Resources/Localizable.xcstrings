      }
    },
    "onboarding.screenRecording.title": {
      "comment": "",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Screen Recording permission"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "屏幕录制权限"
          }
        }
      }
    },
    "onboarding.screenRecording.subtitle": {
      "comment": "",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Required for region, full-screen, and window screenshots."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "区域、全屏和窗口截图都需要此权限。"
          }
        }
      }
    },
    "onboarding.screenRecording.description": {
      "comment": "",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "macOS requires Screen Recording permission before Assistant can capture screenshots. Without it, screenshot features cannot work."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "macOS 要求授予屏幕录制权限后，Assistant 才能进行截图。未授权时截图功能无法使用。"
          }
        }
      }
    },
    "onboarding.accessibility.title": {
      "comment": "",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Accessibility permission"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "辅助功能权限"
          }
        }
      }
    },
    "onboarding.accessibility.subtitle": {
      "comment": "",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Required to support safe system-control workflows."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "用于支持安全的系统控制类工作流。"
          }
        }
      }
    },
    "onboarding.accessibility.description": {
      "comment": "",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Assistant needs Accessibility permission for controlled macOS automation paths such as future auto-paste, window control, simulated shortcuts, and controlling other apps."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "Assistant 需要辅助功能权限，用于受控的 macOS 自动化路径，例如后续自动粘贴、窗口控制、模拟快捷键和控制其他 App。"
          }
        }
      }
    },
    "onboarding.accessibility.boundary": {
      "comment": "",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "MVP uses this permission only within documented Assistant features. It does not run arbitrary shell commands or upload your data."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "MVP 仅在已说明的 Assistant 功能边界内使用此权限，不执行任意 shell，也不会上传你的数据。"
          }
        }
      }
    },
