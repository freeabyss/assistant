    "settings.shortcuts.footer.defaults": {
      "comment": "Footer showing default shortcut values",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Defaults: Toggle Panel ⌘Space · Capture Region ⌘⇧A · Capture Window ⌘⇧W."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "默认：切换面板 ⌘空格 · 区域截图 ⌘⇧A · 窗口截图 ⌘⇧W。"
          }
        }
      }
    },
    "settings.shortcuts.footer.spotlightWarning": {
      "comment": "Warning about ⌘Space conflicting with Spotlight",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Heads up: ⌘Space conflicts with macOS Spotlight by default. To use SnapVault's Command Bar, either change Spotlight's shortcut in System Settings → Keyboard → Keyboard Shortcuts → Spotlight, or pick a different shortcut here."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "注意：⌘空格默认与 macOS Spotlight 冲突。要使用 SnapVault 的命令栏，请在系统设置 → 键盘 → 键盘快捷键 → Spotlight 中修改 Spotlight 的快捷键，或在此处选择其他快捷键。"
          }
        }
      }
    },
    "settings.shortcuts.footer.instructions": {
      "comment": "Instructions for recording shortcuts",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Click a recorder field and press your desired key combination. Capture Region lets you select an area to screenshot. Capture Window captures the window under your cursor."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "点击录制区域并按下你想要的组合键。区域截图可让你选择截图区域，窗口截图可捕捉光标下的窗口。"
          }
        }
      }
    },
    "settings.data.dbSize": {
