    "settings.retention.footer": {
      "comment": "Section footer for Retention settings",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Clipboard items older than the retention period will be automatically deleted. Pinned items are never removed."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "超过保留期限的剪贴板内容将被自动删除。置顶内容不受影响。"
          }
        }
      }
    },
    "settings.launchAtLogin": {
      "comment": "Toggle label for launch at login",
      "localizations": {
        "en": {
          "stringUnit": {
